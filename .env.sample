# Fleet / MQTT hub (HiveMQ default; Mosquitto optional)
ASTRA_MQTT_PROVIDER=hivemq
ASTRA_MQTT_URL=mqtts://YOUR_CLUSTER.s1.eu.hivemq.cloud:8883
ASTRA_MQTT_WS_URL=wss://YOUR_CLUSTER.s1.eu.hivemq.cloud:8884/mqtt
ASTRA_MQTT_USERNAME=mxpfastra
ASTRA_MQTT_PASSWORD="your-password-here"

# Identity (set after approval / onboarding)
# ASTRA_AGENT_ID=astra-web-prod
# ASTRA_AGENT_NAME=web-prod

# Optional local Cursor brain — ONLY on single-tenant trusted hosts
# ASTRA_BRAIN=0
# CURSOR_API_KEY=
